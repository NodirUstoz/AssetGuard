# =============================================================================
# AssetGuard Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://your-domain.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=assetguard
POSTGRES_USER=assetguard
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgres://assetguard:change-this-strong-password@db:5432/assetguard

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@assetguard.local

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=/api

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
